@model ArticleResponse
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb breadcrumb-custom">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Inicio</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="glass-card p-5">
        <h1 class="fw-bold mb-3" style="color: var(--text-dark); font-size: 2.2rem;">@Model.Title</h1>

        <div class="d-flex gap-3 mb-4">
            <span class="badge-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
            </span>
            <span class="badge-date">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                @Model.LastUpdatedAt.ToString("dd MMM yyyy HH:mm")
            </span>
        </div>

        <div class="article-content">
            @if (!string.IsNullOrEmpty(Model.Content))
            {
                <p>@Model.Content</p>
            }
            else
            {
                <p class="fst-italic" style="color: var(--text-soft);">Sin contenido</p>
            }
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn-glass-outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-1"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Volver
        </a>
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
        {
            <a asp-controller="Article" asp-action="Edit" asp-route-id="@Model.Id" class="btn-glass-outline">Editar</a>
        }
    </div>
</div>
