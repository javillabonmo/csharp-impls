@model ArticleRequest
@{
    ViewData["Title"] = "Crear Artículo";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="glass-card p-5">
                <h3 class="fw-bold mb-4" style="color: var(--text-dark);">Crear Nuevo Artículo</h3>

                <form asp-controller="Article" asp-action="Create" method="post">
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label fw-medium" style="color: var(--text-mid);"></label>
                        <input asp-for="Title" class="form-control input-glass" placeholder="Título del artículo" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label fw-medium" style="color: var(--text-mid);"></label>
                        <textarea asp-for="Content" class="form-control input-glass" rows="12" placeholder="Escribe tu contenido aquí..." style="resize: vertical;"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-glass">Guardar</button>
                        <a asp-controller="Home" asp-action="Index" class="btn-glass-outline">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
