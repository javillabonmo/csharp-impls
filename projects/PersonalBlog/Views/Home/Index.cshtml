@model IEnumerable<ArticleResponse>
@{
    ViewData["Title"] = "Inicio";
}
<div class="page-header text-center">
    <h1 class="display-4 text-gradient">PersonalBlog</h1>
    <p>Bienvenido a mi rincón personal</p>
</div>

<div class="container">
    @if (Model is not null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var article in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="glass-card h-100 p-4 d-flex flex-column">
                        <h5 class="fw-bold mb-2" style="color: var(--text-dark);">@article.Title</h5>
                        <p class="flex-grow-1 mb-3" style="color: var(--text-soft); font-size: 0.95rem;">
                            @(article.Content?.Length > 200 ? article.Content[..200] + "..." : article.Content)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="badge-date">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                @article.CreatedAt.ToString("dd MMM yyyy")
                            </span>
                            <a asp-controller="Article" asp-action="Detail" asp-route-id="@article.Id" class="btn-glass-outline btn-sm">Leer más</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/></svg>
            </div>
            <p class="fs-5">No hay artículos aún.</p>
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
            {
                <a asp-controller="Article" asp-action="Create" class="btn-glass mt-3">Crear el primer artículo</a>
            }
        </div>
    }
</div>
